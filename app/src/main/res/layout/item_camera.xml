<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/camera_card_width"
    android:layout_height="@dimen/camera_card_height"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:focusable="true"
    android:clickable="true"
    android:padding="@dimen/card_padding"
    android:layout_margin="@dimen/item_margin">

    <ImageView
        android:id="@+id/ivCameraSnapshot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_camera_placeholder"
        android:contentDescription="@string/camera_snapshot" />

    <TextView
        android:id="@+id/tvCameraName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/item_margin"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/body_text_size"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
